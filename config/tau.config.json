{
  "defaultProfile": "fast",
  "providerKeys": {
    "github-copilot": ["GITHUB_TOKEN", "GH_TOKEN"],
    "openai-codex": []
  },
  "profiles": {
    "deep": {
      "id": "openai-codex/gpt-5.5",
      "thinking": "xhigh"
    },
    "fast": {
      "id": "openai-codex/gpt-5.3-codex-spark",
      "thinking": "low"
    },
    "router": {
      "id": "openai-codex/gpt-5.3-codex-spark",
      "thinking": "low",
      "models": ["fast", "deep"]
    },
    "work": {
      "id": "github-copilot/gpt-5.5",
      "thinking": "medium"
    }
  },
  "aliases": {
    "ask": {
      "extras": ["-p"],
      "profile": "fast"
    },
    "code": {
      "extras": [],
      "profile": "fast"
    },
    "commit": {
      "extras": ["--tools", "read,grep,find,ls,bash", "-p"],
      "profile": "fast",
      "prompt": "Prepare concise conventional commit guidance. Inspect state before proposing text."
    },
    "continue": {
      "extras": ["--continue"],
      "profile": "fast"
    },
    "debug": {
      "extras": ["--tools", "read,grep,find,ls,bash", "-p"],
      "profile": "deep",
      "prompt": "Investigate first. Reproduce, isolate evidence, then suggest the smallest fix."
    },
    "export": {
      "extras": ["--export"],
      "profile": "fast"
    },
    "fix": {
      "extras": [],
      "profile": "fast",
      "prompt": "Fix narrowly. Inspect real state, edit only needed files, test before reporting done."
    },
    "fork": {
      "extras": ["--fork"],
      "profile": "fast"
    },
    "grill": {
      "extras": ["--tools", "read,grep,find,ls", "-p"],
      "profile": "deep",
      "prompt": "Critique the plan hard. Surface risks, weak assumptions, missing tests, and open questions."
    },
    "plan": {
      "extras": ["--tools", "read,grep,find,ls", "-p"],
      "profile": "fast",
      "prompt": "Plan first. Do not implement unless explicitly asked. End with unresolved questions."
    },
    "pr": {
      "extras": ["--tools", "read,grep,find,ls,bash", "-p"],
      "profile": "fast",
      "prompt": "Prepare concise PR text with summary, tests, risks, and checklist."
    },
    "resume": {
      "extras": ["--resume"],
      "profile": "fast"
    },
    "review": {
      "extras": ["--tools", "read,grep,find,ls", "-p"],
      "profile": "fast"
    },
    "ship": {
      "extras": [],
      "profile": "fast",
      "prompt": "Implement explicitly. Edit, test, document, and verify before reporting done."
    }
  },
  "extensionPresets": {
    "banner": {
      "extensions": ["tau-banner.ts"],
      "profile": "fast"
    },
    "cc": {
      "extensions": ["theme-cycler.ts", "cc-header.ts", "cc-editor.ts", "cc-spinner.ts", "cc-tools.ts"],
      "themes": ["tau-cc", "picpay"],
      "profile": "fast"
    },
    "work": {
      "extensions": ["theme-cycler.ts", "cc-header.ts", "cc-editor.ts", "cc-spinner.ts", "cc-tools.ts"],
      "themes": ["tau-cc", "picpay"],
      "brand": "picpay",
      "profile": "fast"
    },
    "chain": {
      "extensions": ["tau-banner.ts", "persona-selector.ts", "status-footer.ts", "tool-counter-footer.ts"],
      "profile": "fast"
    },
    "damage": {
      "extensions": ["tau-banner.ts", "damage-control.ts", "status-footer.ts", "tool-counter-footer.ts"],
      "profile": "fast",
      "prompt": "Damage control active. If a tool is blocked, continue with a safe alternative and explain the smaller next step."
    },
    "damage-continue": {
      "extensions": ["tau-banner.ts", "damage-control.ts", "status-footer.ts", "tool-counter-footer.ts"],
      "profile": "fast",
      "prompt": "Damage control continue mode. Treat blocks as feedback. Do not stop; choose a safe read-only or narrower alternative."
    },
    "focus": {
      "extensions": ["purpose-gate.ts", "task-discipline.ts", "pure-focus.ts", "status-footer.ts"],
      "profile": "fast"
    },
    "minimal": {
      "extensions": ["tau-banner.ts", "status-footer.ts"],
      "profile": "fast"
    },
    "orchestrate": {
      "extensions": [
        "tau-banner.ts",
        "subagent-mode.ts",
        "session-replay.ts",
        "cross-agent-loader.ts",
        "status-footer.ts",
        "tool-counter-footer.ts"
      ],
      "profile": "fast",
      "prompt": "Advanced orchestration active. Use /sub for isolated background research, /replay for audit timeline, and /xload to inspect safe cross-agent assets."
    },
    "safe": {
      "extensions": [
        "tau-banner.ts",
        "purpose-gate.ts",
        "task-discipline.ts",
        "damage-control.ts",
        "status-footer.ts",
        "tool-counter-footer.ts"
      ],
      "profile": "fast",
      "prompt": "Use purpose and task discipline. Damage control is active; continue with safe alternatives when blocked."
    },
    "team": {
      "extensions": ["tau-banner.ts", "persona-selector.ts", "status-footer.ts", "tool-counter-footer.ts"],
      "profile": "fast"
    },
    "vibe": {
      "extensions": ["tau-banner.ts", "theme-cycler.ts", "status-footer.ts", "tool-counter-footer.ts"],
      "profile": "fast"
    }
  }
}
